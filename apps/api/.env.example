# ---- Server ----
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ---- JWT ----
# JWT_SECRET (removed: access and refresh now use SEPARATE secrets)
# OLD_JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- SQL Server (restore db_aajiveka.bak, then point here) ----
DB_SERVER=localhost
DB_NAME=db_aajiveka
DB_USER=sa
DB_PASSWORD=your-password
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

# 2Factor SMS OTP + SMTP (see reference Web.config). Leave blank to disable.
TWOFACTOR_API_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# PostgreSQL (Prisma) — the rebuild target
DATABASE_URL="postgresql://aajiveka:aajiveka@localhost:15432/aajiveka?schema=public"

# Access and refresh tokens are signed with SEPARATE secrets, so a refresh token cannot be
# used as an access token. Min 32 chars; required in production (no default).
JWT_ACCESS_SECRET="replace-with-a-real-32-plus-char-secret"
JWT_REFRESH_SECRET="replace-with-a-different-32-plus-char-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
