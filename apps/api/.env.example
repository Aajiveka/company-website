# ---- Server ----
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ---- JWT ----
# JWT_SECRET (removed: access and refresh now use SEPARATE secrets)
# OLD_JWT_SECRET=change-me-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ---- SQL Server (restore db_aajiveka.bak, then point here) ----
DB_SERVER=localhost
DB_NAME=db_aajiveka
DB_USER=sa
DB_PASSWORD=your-password
DB_PORT=1433
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=true

# (Legacy 2Factor/SMTP vars moved to bottom — see notification drivers section)

# PostgreSQL (Prisma) — the rebuild target. The port is the one docker-compose.dev.yml
# publishes, not 5432: `docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d`.
DATABASE_URL="postgresql://aajiveka:aajiveka@localhost:15432/aajiveka?schema=public"

# Access and refresh tokens are signed with SEPARATE secrets, so a refresh token cannot be
# used as an access token. Min 32 chars; required in production (no default).
JWT_ACCESS_SECRET="replace-with-a-real-32-plus-char-secret"
JWT_REFRESH_SECRET="replace-with-a-different-32-plus-char-secret"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# Redis — backs BullMQ and the OTP store. Port published by docker-compose.dev.yml.
REDIS_URL="redis://localhost:16379"
APP_URL="http://localhost:5173"

# Notification drivers: 'log' (default, dev), 'sns'/'twofactor' for SMS, 'ses'/'smtp' for email.
SMS_DRIVER=log
EMAIL_DRIVER=log

# AWS SNS (SMS_DRIVER=sns) — uses EC2 instance role credentials, no keys needed.
SNS_SENDER_ID=

# AWS SES (EMAIL_DRIVER=ses) — verified sender address.
SES_FROM_EMAIL=

# 2Factor.in (SMS_DRIVER=twofactor)
# TWOFACTOR_API_KEY=

# SMTP (EMAIL_DRIVER=smtp)
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
