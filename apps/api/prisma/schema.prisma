model JobSubscriberMapping {
  jobSubscriberMapID           BigInt                             @id @default(autoincrement()) @map("JobSubscriberMapID")
  jobID                        BigInt?                            @map("JobID")  // FK -> ClientJobs (confirmed)
  subscriberID                 BigInt?                            @map("SubscriberID")  // FK -> SubscriberRegistration (confirmed)
  mapDate                      DateTime? @db.Date                 @map("MapDate")
  jobMapStatusID               Int?                               @map("JobMapStatusID")  // FK -> MstrJobMappingStatus (confirmed)
  timestampIns                 DateTime? @db.Timestamp(6)         @map("TimestampIns")
  loginIDIns                   BigInt?                            @map("LoginIDIns")
  timestampUpd                 DateTime? @db.Timestamp(6)         @map("TimestampUpd")
  loginIDUpd                   BigInt?                            @map("LoginIDUpd")

  job                          ClientJobs?                        @relation("JobSubscriberMappingToClientJobs", fields: [jobID], references: [jobID])
  jobMapStatus                 MstrJobMappingStatus?              @relation("JobSubscriberMappingToMstrJobMappingStatus", fields: [jobMapStatusID], references: [jobMapStatusID])
  subscriber                   SubscriberRegistration?            @relation("JobSubscriberMappingToSubscriberRegistration", fields: [subscriberID], references: [subscriberID])
  CandidateDocumentMap         CandidateDocumentMap[]             @relation("CandidateDocumentMapToJobSubscriberMapping")
  JobInterviewStatus           JobInterviewStatus[]               @relation("JobInterviewStatusToJobSubscriberMapping")
  JobSubscriberStatus          JobSubscriberStatus[]              @relation("JobSubscriberStatusToJobSubscriberMapping")
