model PaymentOrder {
  orderID                      BigInt                             @id @default(autoincrement()) @map("OrderID")
  /// Our reference, sent to BillDesk as orderid. Unique and unguessable.
  orderRef                     String @db.VarChar(40)             @unique @map("OrderRef")
  subscriberID                 BigInt                             @map("SubscriberID")
  planID                       Int                                @map("PlanID")
  /// Copied from the plan at creation time, so a later price change cannot alter a past order.
  amountInr                    Int                                @map("AmountINR")
  status                       PaymentStatus                      @default(CREATED) @map("Status")

  /// BillDesk's own order id, returned by the create-order call.
  bdOrderId                    String? @db.VarChar(60)            @map("BDOrderID")
  /// The transaction id on the settled payment.
  transactionId                String? @db.VarChar(60)            @unique @map("TransactionID")
  authStatus                   String? @db.VarChar(10)            @map("AuthStatus")
  paymentMethod                String? @db.VarChar(40)            @map("PaymentMethod")
  errorDescription             String? @db.VarChar(300)           @map("ErrorDescription")
  /// The verified JWS payload, as received. Kept for dispute resolution.
  rawResponse                  String? @db.Text                   @map("RawResponse")

  createdAt                    DateTime @db.Timestamp(6)          @default(now()) @map("CreatedAt")
  settledAt                    DateTime? @db.Timestamp(6)         @map("SettledAt")

  subscriber                   SubscriberRegistration             @relation("PaymentOrderToSubscriberRegistration", fields: [subscriberID], references: [subscriberID])
  plan                         SubscriptionPlan                   @relation("PaymentOrderToSubscriptionPlan", fields: [planID], references: [planID])
  subscription                 Subscription?                      @relation("SubscriptionToPaymentOrder")

  @@index([subscriberID])
  @@index([status])
  @@map("tblPaymentOrder")
}

/// What a successful payment actually buys. Also new.
model Subscription {
  subscriptionID               BigInt                             @id @default(autoincrement()) @map("SubscriptionID")
  subscriberID                 BigInt                             @map("SubscriberID")
  planID                       Int                                @map("PlanID")
  /// One subscription row per paid order — this is what makes activation idempotent.
  orderID                      BigInt                             @unique @map("OrderID")
  startsAt                     DateTime @db.Timestamp(6)          @map("StartsAt")
  endsAt                       DateTime @db.Timestamp(6)          @map("EndsAt")
  createdAt                    DateTime @db.Timestamp(6)          @default(now()) @map("CreatedAt")

  subscriber                   SubscriberRegistration             @relation("SubscriptionToSubscriberRegistration", fields: [subscriberID], references: [subscriberID])
  plan                         SubscriptionPlan                   @relation("SubscriptionToSubscriptionPlan", fields: [planID], references: [planID])
  order                        PaymentOrder                       @relation("SubscriptionToPaymentOrder", fields: [orderID], references: [orderID])

  @@index([subscriberID])
  @@map("tblSubscription")
}
