  job                          ClientJobs                         @relation("ClientJobSkillToClientJobs", fields: [jobID], references: [jobID])
  skill                        MstrSkills                         @relation("ClientJobSkillToMstrSkills", fields: [skillID], references: [skillID])
  @@map("tblClientJobSkill")
}

model ClientJobs {
  jobID                        BigInt                             @id @default(autoincrement()) @map("JobID")
  clientID                     BigInt                             @map("ClientID")  // FK -> ClientMstr (confirmed)
  designationID                Int                                @map("DesignationID")  // FK -> MstrDesignation (confirmed)
  employeeTypeID               Int                                @map("EmployeeTypeID")  // FK -> MstrEmpType (confirmed)
  workModeID                   Int                                @map("WorkModeID")  // FK -> MstrWorkMode (confirmed)
  jobDescr                     String? @db.Text                   @map("JobDescr")
  jobCandidateProfile          String? @db.Text                   @map("JobCandidateProfile")
  minExp                       Int?                               @map("MinExp")
  maxEmp                       Int?                               @map("MaxEmp")
  minCTC                       Int                                @map("MinCTC")
  maxCTC                       Int                                @map("MaxCTC")
  jobCityID                    Int                                @map("JobCityID")  // FK -> MstrCily (confirmed)
  statusID                     Int?                               @map("StatusID")  // FK -> MstrStatus (confirmed) (widened from tinyint)
  timestampIns                 DateTime @db.Timestamp(6)          @map("TimestampIns")
  loginIDIns                   BigInt                             @map("LoginIDIns")
  timestampUpd                 DateTime? @db.Timestamp(6)         @map("TimestampUpd")
  loginIDUpd                   BigInt?                            @map("LoginIDUpd")
  industryTypeID               Int?                               @map("IndustryTypeID")  // FK -> MstrIndustryType (confirmed)

  client                       ClientMstr                         @relation("ClientJobsToClientMstr", fields: [clientID], references: [clientID])
  designation                  MstrDesignation                    @relation("ClientJobsToMstrDesignation", fields: [designationID], references: [designationID])
  employeeType                 MstrEmpType                        @relation("ClientJobsToMstrEmpType", fields: [employeeTypeID], references: [employeeTypeID])
  industryType                 MstrIndustryType?                  @relation("ClientJobsToMstrIndustryType", fields: [industryTypeID], references: [industryTypeID])
  jobCity                      MstrCily                           @relation("ClientJobsToMstrCily", fields: [jobCityID], references: [cityID])
  workMode                     MstrWorkMode                       @relation("ClientJobsToMstrWorkMode", fields: [workModeID], references: [workModeID])
  ClientJobSkill               ClientJobSkill[]                   @relation("ClientJobSkillToClientJobs")
  ClientJobs_EducationType     ClientJobs_EducationType[]         @relation("ClientJobs_EducationTypeToClientJobs")
  ClientJobs_Gendermapping     ClientJobs_Gendermapping[]         @relation("ClientJobs_GendermappingToClientJobs")
  JobSubscriberMapping         JobSubscriberMapping[]             @relation("JobSubscriberMappingToClientJobs")
  SubscriberJobStatusLatest    SubscriberJobStatusLatest[]        @relation("SubscriberJobStatusLatestToClientJobs")
  SubscriberStatusHistory      SubscriberStatusHistory[]          @relation("SubscriberStatusHistoryToClientJobs")
  @@map("tblClientJobs")
}

model ClientJobs_EducationType {
  jobID                        BigInt                             @map("JobID")  // FK -> ClientJobs (confirmed)
  educationTypeID              Int                                @map("EducationTypeID")  // FK -> MstrEducationType (confirmed)

  educationType                MstrEducationType                  @relation("ClientJobs_EducationTypeToMstrEducationType", fields: [educationTypeID], references: [educationTypeID])
  job                          ClientJobs                         @relation("ClientJobs_EducationTypeToClientJobs", fields: [jobID], references: [jobID])

  @@id([jobID, educationTypeID])
  @@map("tblClientJobs_EducationType")
}

model ClientJobs_Gendermapping {
  jobID                        BigInt                             @map("JobID")  // FK -> ClientJobs (confirmed)
  gender                       String @db.Char(1)                 @map("Gender")

  job                          ClientJobs                         @relation("ClientJobs_GendermappingToClientJobs", fields: [jobID], references: [jobID])

  @@id([jobID, gender])
  @@map("tblClientJobs_Gendermapping")
}

model ClientMstr {
  clientID                     BigInt                             @id @default(autoincrement()) @map("ClientID")
  clientName                   String @db.VarChar(200)            @map("ClientName")
  clientAddress                String? @db.VarChar(500)           @map("ClientAddress")
  pIN                          Int?                               @map("PIN")
  contactNo                    String? @db.VarChar(50)            @map("ContactNo")
  emailID                      String? @db.VarChar(50)            @map("EmailID")
  companyLogo                  String? @db.VarChar(200)           @map("CompanyLogo")
  cityID                       Int                                @map("CityID")  // FK -> MstrCily (confirmed)
  companyWebsite               String? @db.VarChar(100)           @map("companyWebsite")
  companyDescr                 String? @db.VarChar(5000)          @map("companyDescr")
  timestampIns                 DateTime @db.Timestamp(6)          @map("TimestampIns")
  loginIDIns                   BigInt                             @map("LoginIDIns")
  timestampUpd                 DateTime? @db.Timestamp(6)         @map("TimestampUpd")
  loginIDUpd                   BigInt?                            @map("LoginIDUpd")
  userID                       BigInt?                            @map("UserID")  // FK -> SecUser (confirmed)
  industryTypeID               Int?                               @map("IndustryTypeID")  // FK -> MstrIndustryType (confirmed)

  city                         MstrCily                           @relation("ClientMstrToMstrCily", fields: [cityID], references: [cityID])
  industryType                 MstrIndustryType?                  @relation("ClientMstrToMstrIndustryType", fields: [industryTypeID], references: [industryTypeID])
  user                         SecUser?                           @relation("ClientMstrToSecUser", fields: [userID], references: [userID])
  ClientContacts               ClientContacts[]                   @relation("ClientContactsToClientMstr")
  ClientJobs                   ClientJobs[]                       @relation("ClientJobsToClientMstr")
  MstrPerson                   MstrPerson[]                       @relation("MstrPersonToClientMstr")
  SubscriberJobStatusLatest    SubscriberJobStatusLatest[]        @relation("SubscriberJobStatusLatestToClientMstr")
  SubscriberStatusHistory      SubscriberStatusHistory[]          @relation("SubscriberStatusHistoryToClientMstr")
  @@map("tblClientMstr")
}

