// Aajiveka — PostgreSQL schema
//
// Derived from a real restore of db_aajiveka.bak, NOT inferred. Column types,
// nullability and identity come straight from the SQL Server catalog.
//
// The legacy database declared ZERO foreign keys and left 36 of 73 tables without a
// primary key. None of that is mirrored here. Every relation below was derived from the
// JOIN clauses in db/procs/ and then VALIDATED against the real data with an orphan
// check — see db/foreign-keys.psv for the evidence and confidence of each one.
//
// 13 dead tables (no rows, referenced by no procedure) are omitted — see db/dead-tables.txt.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CandidateDocumentMap {
  documentMapID                BigInt                             @id @default(autoincrement()) @map("DocumentMapID")
  jobSubscriberMapID           BigInt?                            @map("JobSubscriberMapID")  // FK -> JobSubscriberMapping (unverified-empty)
  subscriberID                 BigInt?                            @map("SubscriberID")
  documentTypeID               Int?                               @map("DocumentTypeID")  // FK -> MstrDocumentType (unverified-empty)
  flgStatus                    Int? @db.SmallInt                  @map("flgStatus")
  timestampIns                 DateTime? @db.Timestamp(6)         @map("TimestampIns")
  loginIDIns                   Int?                               @map("LoginIDIns")
  timestampUpd                 DateTime? @db.Timestamp(6)         @map("TimestampUpd")
  loginIDUpd                   Int?                               @map("LoginIDUpd")

  documentType                 MstrDocumentType?                  @relation("CandidateDocumentMapToMstrDocumentType", fields: [documentTypeID], references: [documentTypeID])
  jobSubscriberMap             JobSubscriberMapping?              @relation("CandidateDocumentMapToJobSubscriberMapping", fields: [jobSubscriberMapID], references: [jobSubscriberMapID])
  CandidateDocumentUploaded    CandidateDocumentUploaded[]        @relation("CandidateDocumentUploadedToCandidateDocumentMap")
  @@map("tblCandidateDocumentMap")
}

model CandidateDocumentStatus {
  docStatusID                  BigInt                             @id @default(autoincrement()) @map("DocStatusID")
  docUploadID                  BigInt?                            @map("DocUploadID")
  statusID                     Int?                               @map("StatusID")
  comments                     String? @db.VarChar(1000)          @map("comments")
  userID                       BigInt?                            @map("UserID")
  timestampIns                 DateTime? @db.Timestamp(6)         @map("TimestampIns")
  loginIDIns                   Int?                               @map("LoginIDIns")
  @@map("tblCandidateDocumentStatus")
}

model CandidateDocumentUploaded {
  docUploadID                  BigInt                             @id @default(autoincrement()) @map("DocUploadID")
  documentMapID                BigInt?                            @map("DocumentMapID")  // FK -> CandidateDocumentMap (unverified-empty)
  subscriberID                 BigInt?                            @map("SubscriberID")
  documentTypeID               Int?                               @map("DocumentTypeID")  // FK -> MstrDocumentType (unverified-empty)
  documentPath                 String? @db.VarChar(500)           @map("DocumentPath")
  flgStatus                    Int? @db.SmallInt                  @map("flgStatus")
  timestampIns                 DateTime? @db.Timestamp(6)         @map("TimestampIns")
  loginIDIns                   Int?                               @map("LoginIDIns")
  timestampUpd                 DateTime? @db.Timestamp(6)         @map("TimestampUpd")
  loginIDUpd                   Int?                               @map("LoginIDUpd")

  documentMap                  CandidateDocumentMap?              @relation("CandidateDocumentUploadedToCandidateDocumentMap", fields: [documentMapID], references: [documentMapID])
  documentType                 MstrDocumentType?                  @relation("CandidateDocumentUploadedToMstrDocumentType", fields: [documentTypeID], references: [documentTypeID])
  @@map("tblCandidateDocumentUploaded")
}

model ClientContacts {
  clientContactsID             BigInt                             @id @default(autoincrement()) @map("ClientContactsID")
  clientID                     BigInt                             @map("ClientID")  // FK -> ClientMstr (confirmed)
  contactPerName               String @db.VarChar(100)            @map("ContactPerName")
  phoneNo                      String? @db.VarChar(20)            @map("PhoneNo")
  mobile                       String? @db.VarChar(20)            @map("Mobile")
  emailID                      String? @db.VarChar(100)           @map("EmailID")
  roleID                       Int                                @map("RoleID")
  contactPersonRole            String? @db.VarChar(50)            @map("ContactPersonRole")

  client                       ClientMstr                         @relation("ClientContactsToClientMstr", fields: [clientID], references: [clientID])
  @@map("tblClientContacts")
}

model ClientJobSkill {
