{
  "name": "@aajiveka/api",
  "private": true,
  "version": "1.0.0",
  "main": "dist/main.js",
  "scripts": {
    "predev": "lsof -ti tcp:${PORT:-4000} | xargs kill -9 2>/dev/null || true",
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "node --import tsx --test src/**/*.test.ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:generate": "prisma generate",
    "db:migrate-legacy": "tsx prisma/migrate-data.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/client-sesv2": "^3.1090.0",
    "@aws-sdk/client-sns": "^3.1090.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.28",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.28",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/platform-express": "^11.1.28",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.80.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.11.1",
    "nestjs-pino": "^4.6.1",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.19.1",
    "pg": "^8.22.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "tsx": "^4.16.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@nestjs/cli": "^11.0.24",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.28",
    "@types/express": "^5.0.6",
    "@types/mssql": "^12.3.0",
    "@types/multer": "^2.2.0",
    "@types/node": "^20.14.10",
    "@types/nodemailer": "^8.0.1",
    "@types/pdfkit": "^0.17.6",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "eslint": "^9.39.5",
    "globals": "^17.7.0",
    "mssql": "^12.7.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "tsc-alias": "^1.8.10",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.63.0"
  }
