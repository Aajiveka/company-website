{
  "name": "aajiveka",
  "version": "1.0.0",
  "private": true,
  "description": "AajivikaPortal — modern React + Node/TS rebuild of the ATS recruitment portal",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "concurrently -n api,web,pay -c blue,green,magenta -k \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:billdesk\"",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "predev:billdesk": "lsof -ti tcp:${STUB_PORT:-4999} | xargs kill -9 2>/dev/null || true",
    "dev:billdesk": "node tests/billdesk-stub.mjs",
    "build": "npm run build --workspace apps/web && npm run build --workspace apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "concurrently": "^9.1.0",
    "wait-on": "^9.0.10"
  }
}
