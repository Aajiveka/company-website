{
  "name": "aajiveka",
  "version": "1.0.0",
  "private": true,
  "description": "AajivikaPortal — modern React + Node/TS rebuild of the ATS recruitment portal",
  "workspaces": [
    "apps/web",
    "apps/api"
  ],
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "build": "npm run build --workspace apps/web && npm run build --workspace apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "wait-on": "^9.0.10"
  }
}
