# docker compose reads this file. Copy to .env and fill it in.

POSTGRES_USER=aajiveka
POSTGRES_DB=aajiveka
POSTGRES_PASSWORD=            # required

# Access and refresh tokens are signed with SEPARATE secrets — do not reuse one for both.
# Generate each with:  openssl rand -hex 32
JWT_ACCESS_SECRET=            # required, >= 32 chars
JWT_REFRESH_SECRET=           # required, >= 32 chars

WEB_PORT=8080
APP_URL=http://localhost:8080

# Storage: local (disk, in the `uploads` volume) or s3.
STORAGE_DRIVER=local
# S3_BUCKET=
# AWS_REGION=ap-south-1

# Notifications. WITHOUT THESE, EMAIL AND SMS ARE LOGGED, NOT SENT — the API says so at
# boot. The values in the legacy Web.config are compromised and must be rotated first.
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASSWORD=
# TWOFACTOR_API_KEY=

# BillDesk. Without these, POST /payments/orders returns 400 instead of pretending.
# NEVER reuse the values from the legacy Web.config — they are compromised.
# BILLDESK_BASE_URL=https://api.billdesk.com
# BILLDESK_CLIENT_ID=
# BILLDESK_MERCHANT_ID=
# BILLDESK_SECRET_KEY=
